# Shopify
SHOPIFY_STORE_DOMAIN=your-dev-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_API_VERSION=2026-01

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/inventory_agent

# LLM Provider (at least one required for production)
LLM_PROVIDER=openai
OPENAI_API_KEY=
GOOGLE_API_KEY=

# API Authentication
AGENT_API_KEY=demo-key-2024

# Optional
MODEL_NAME=gemini-2.0-flash
TEMPERATURE=0.3
MAX_TOKENS=1024

# Notifications
SLACK_WEBHOOK_URL=

# Shopify Webhooks (shared secret from Shopify App setup page)
SHOPIFY_WEBHOOK_SECRET=

# Checkpointer DB (for LangGraph pause/resume — psycopg scheme, not asyncpg)
CHECKPOINTER_DATABASE_URL=postgresql://inventory:inventory@localhost:5432/inventory_agent
